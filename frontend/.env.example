# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# SQLite database path (relative to this directory)
DATABASE_URL=file:../../backend/db/custom.db

# URL of the StratAPI backend service (no trailing slash)
BACKEND_URL=http://127.0.0.1:3001

# Firebase project ID (safe to expose — it's public config)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBHQMgDtV-JlRfBNgiwpcplMaOLL1IoRP8
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=stratapi-77837.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=stratapi-77837
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=stratapi-77837.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=479960904781
NEXT_PUBLIC_FIREBASE_APP_ID=1:479960904781:web:eaa0811bda5d8627351804
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-VC63LB4XBD

# Firebase backend gateway URL (used client-side to build gateway request URLs)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ── Production only ──────────────────────────────────────────────────────────
# Firebase service account JSON (single-line, from Firebase Console →
# Project Settings → Service Accounts → Generate new private key)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"stratapi-77837",...}
