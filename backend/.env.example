# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in your values.

NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# MongoDB — use Atlas connection string in production
MONGODB_URI=mongodb://127.0.0.1:27017/stratapi

# Redis — use Upstash or Redis Cloud in production
REDIS_URL=redis://127.0.0.1:6379

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret-min-32-chars
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret-min-32-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# CORS — set to your frontend domain in production
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
GATEWAY_TIMEOUT_MS=15000
REQUEST_BODY_LIMIT=1mb

# Billing
FREE_TIER_REQUESTS=1000
PRICE_PER_100_REQUESTS_INR=0.5
BILLING_JOB_INTERVAL_MS=3600000
API_KEY_PREFIX=sa_live

# Razorpay (optional — billing won't work without it)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_CURRENCY=INR

LOG_LEVEL=info
