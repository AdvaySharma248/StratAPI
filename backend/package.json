{
  "name": "stratapi-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Production backend for the StratAPI usage-based API billing platform.",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "worker": "node jobs/worker.js",
    "db:push": "npm --prefix ../frontend run db:push",
    "db:generate": "npm --prefix ../frontend run db:generate",
    "db:migrate": "npm --prefix ../frontend run db:migrate",
    "db:reset": "npm --prefix ../frontend run db:reset"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.0",
    "morgan": "^1.10.1",
    "razorpay": "^2.9.6",
    "zod": "^4.3.6"
  }
}
